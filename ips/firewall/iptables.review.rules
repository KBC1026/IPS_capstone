# Review-only iptables candidate.
# Do not apply directly on the IPS server without taking a backup first:
#   sudo iptables-save > ~/iptables.backup.$(date +%Y%m%d-%H%M%S).rules
#
# Goal:
# - Keep Tailscale chains.
# - Keep internal network NAT through ens18.
# - Remove duplicated FORWARD and MASQUERADE rules.
# - Avoid broad new inbound forwarding from ens18 to ens19.
#
# This is intentionally not loaded by the project. Review with:
#   diff -u ips/firewall/iptables.rules ips/firewall/iptables.review.rules

*mangle
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
-A PREROUTING -m conntrack --ctstate RELATED,ESTABLISHED -j CONNMARK --restore-mark --nfmask 0xff0000 --ctmask 0xff0000
-A OUTPUT -m conntrack --ctstate NEW -m mark ! --mark 0x0/0xff0000 -j CONNMARK --save-mark --nfmask 0xff0000 --ctmask 0xff0000
COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:ts-forward - [0:0]
:ts-input - [0:0]
-A INPUT -j ts-input
-A FORWARD -j ts-forward

# Internal clients can initiate outbound connections through the IPS.
-A FORWARD -i ens19 -o ens18 -m conntrack --ctstate NEW,RELATED,ESTABLISHED -j ACCEPT

# External side can only return traffic for established internal sessions.
-A FORWARD -i ens18 -o ens19 -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

# Tailscale-managed policy copied from the current ruleset.
-A ts-forward -i tailscale0 -j MARK --set-xmark 0x40000/0xff0000
-A ts-forward -m mark --mark 0x40000/0xff0000 -j ACCEPT
-A ts-forward -s 100.64.0.0/10 -o tailscale0 -j DROP
-A ts-forward -o tailscale0 -j ACCEPT
-A ts-input -s 100.104.43.19/32 -i lo -j ACCEPT
-A ts-input -s 100.115.92.0/23 ! -i tailscale0 -j RETURN
-A ts-input -s 100.64.0.0/10 ! -i tailscale0 -j DROP
-A ts-input -i tailscale0 -j ACCEPT
-A ts-input -p udp -m udp --dport 41641 -j ACCEPT
COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
:ts-postrouting - [0:0]
-A POSTROUTING -j ts-postrouting
-A POSTROUTING -o ens18 -j MASQUERADE
-A ts-postrouting -m mark --mark 0x40000/0xff0000 -j MASQUERADE
COMMIT
