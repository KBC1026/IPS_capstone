# ==========================================
# [Capstone Project] 통합 탐지 룰 세트
# ==========================================

# 1. Brute Force (SSH 접속 시도 탐지)
# 1분 동안 5번 이상 접속 시도 시 알람
# alert tcp any any -> any 22 (msg:"SSH Brute Force Attempt"; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000001; rev:1;)

# 2. Port Scan (SYN 스캔 탐지)
# 짧은 시간 내에 여러 포트로 접속을 시도하는 경우
# alert tcp any any -> $HOME_NET any (msg:"TCP Port Scan Detected"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:1000002; rev:1;)

# 3. SQL Injection (HTTP GET/POST 탐지)
# URL이나 데이터에 SQL 예약어(SELECT, UNION 등)가 포함된 경우
# alert tcp any any -> $HTTP_SERVERS any (msg:"SQL Injection Detected - SELECT"; content:"select"; nocase; sid:1000003; rev:1;)
# alert tcp any any -> $HTTP_SERVERS any (msg:"SQL Injection Detected - UNION"; content:"union"; nocase; sid:1000004; rev:1;)
